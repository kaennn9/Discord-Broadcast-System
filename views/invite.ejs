<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Access - Discord Broadcast</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel='stylesheet' href='https://cdn-uicons.flaticon.com/2.1.0/uicons-regular-rounded/css/uicons-regular-rounded.css'>
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }
        .login-card {
            width: 100%;
            max-width: 400px;
            padding: 40px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="server-bg-overlay" style="background-image: url('/models/Background.jpg'); opacity: 0.8; filter: blur(10px) brightness(0.4);"></div>

    <div class="card login-card">
        <div style="font-size: 50px; color: var(--accent); margin-bottom: 20px;">
            <i class="fi fi-rr-lock"></i>
        </div>
        <h2 style="margin-top: 0;">Secure Access</h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 30px;">Enter the password to access this server's dashboard.</p>
        
        <% if (error) { %>
            <div style="background: rgba(255, 60, 60, 0.2); border: 1px solid var(--danger); color: var(--danger); padding: 10px; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
                <%= error %>
            </div>
        <% } %>

        <form action="/invite/<%= code %>" method="POST" id="inviteForm">
            <input type="hidden" name="deviceId" id="deviceIdInput" value="">
            <div class="form-group" style="text-align: left;">
                <label>Password</label>
                <input type="password" name="password" required placeholder="Enter invite password..." autofocus>
            </div>
            <button type="submit" class="btn" style="width: 100%; padding: 12px; font-size: 16px;"><i class="fi fi-rr-unlock"></i> Unlock Dashboard</button>
        </form>
    </div>

    <script>
        // Device Fingerprinting Logic
        let deviceId = localStorage.getItem('broadcast_device_id');
        if (!deviceId) {
            // Generate a random unique ID for this browser
            deviceId = 'device_' + Math.random().toString(36).substring(2) + Date.now().toString(36);
            localStorage.setItem('broadcast_device_id', deviceId);
        }
        document.getElementById('deviceIdInput').value = deviceId;
    </script>
</body>
</html>
