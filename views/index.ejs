<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discord Broadcast Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel='stylesheet'
        href='https://cdn-uicons.flaticon.com/2.1.0/uicons-regular-rounded/css/uicons-regular-rounded.css'>
</head>

<body>
    <!-- Premium Background -->
    <div class="server-bg-overlay" style="background-image: url('/models/Background.jpg'); opacity: 0.8; filter: blur(10px) brightness(0.4);"></div>

    <div class="app-container">
        <!-- Sidebar Icons (Guilds) -->
        <div class="guild-list">
            <a href="/" class="guild-icon" title="Dashboard"><i class="fi fi-rr-home"></i></a>
            <div style="width: 32px; height: 2px; background: rgba(255,255,255,0.2); margin: 4px 0;"></div>
            <% for(const id in bots) { %>
                <a href="/server/<%= bots[id].id %>/<%= bots[id].guildId %>" class="guild-icon"
                    title="<%= bots[id].guildId %>">
                    <%= bots[id].guildId.substring(0, 2) %>
                </a>
                <% } %>
        </div>

        <div class="main-content">
            <div class="topbar" style="display: flex; justify-content: space-between; align-items: center;">
                <div><i class="fi fi-rr-apps" style="margin-right: 10px;"></i> Dashboard</div>
                <a href="/logout" class="btn btn-danger" style="padding: 6px 12px; font-size: 13px; text-decoration: none; background: #8a2a2a;"><i class="fi fi-rr-sign-out-alt"></i> Logout</a>
            </div>
            <div class="content-body">
                
                <!-- Premium Banner -->
                <div style="position: relative; width: 100%; height: 220px; border-radius: 16px; overflow: hidden; margin-bottom: 30px; box-shadow: 0 10px 40px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05);">
                    <img src="/models/Banner.webp" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
                    <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(18,18,18,0.95), rgba(18,18,18,0.2) 60%); display: flex; align-items: flex-end; padding: 30px;">
                        <div>
                            <h1 style="margin: 0; font-size: 32px; font-weight: 800; letter-spacing: 1px; color: white; text-shadow: 0 2px 10px rgba(0,0,0,0.8);"><i class="fi fi-rr-rocket-lunch"></i> Broadcast Control Center</h1>
                            <p style="margin: 8px 0 0 0; color: #e0e0e0; font-size: 15px; max-width: 600px; line-height: 1.5;">Manage your Discord bots, orchestrate parallel broadcasts with helpers, and monitor live statistics from this premium dashboard.</p>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <h2><i class="fi fi-rr-robot"></i> Add New Bot</h2>
                    <form action="/bot/start" method="POST" id="addBotForm">
                        <div class="form-group">
                            <label>Discord Bot Token</label>
                            <input type="password" name="token" id="botTokenInput" required placeholder="Paste bot token here...">
                        </div>
                        <div class="form-group" id="guildInputContainer">
                            <label>Server ID <span style="font-size: 11px; color: #a1a1aa; font-weight: normal;">(Leave empty to choose from list)</span></label>
                            <input type="text" name="guildId" id="guildIdInput" placeholder="Server ID to manage (Optional)...">
                        </div>
                        <button type="submit" class="btn" id="submitBotBtn" style="width: 100%;"><i class="fi fi-rr-play"></i> Start Bot</button>
                    </form>
                </div>

                <div class="card">
                    <h2><i class="fi fi-rr-chart-network"></i> Active Bots</h2>
                    <table style="width: 100%; text-align: left; border-collapse: collapse;">
                        <thead>
                            <tr>
                                <th>Bot</th>
                                <th>Guild ID</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(const id in bots) { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 12px;">
                                            <div style="position: relative; cursor: pointer;"
                                                onclick="document.getElementById('avatar-input-<%= bots[id].id %>').click()"
                                                title="Click to change avatar">
                                                <img src="<%= bots[id].botAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                                    style="width: 48px; height: 48px; border-radius: 50%; border: 2px solid var(--accent); box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                                                <div
                                                    style="position: absolute; bottom: 0; right: 0; background: var(--success); width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--bg-card);">
                                                </div>
                                            </div>
                                            <form action="/bot/avatar" method="POST" enctype="multipart/form-data"
                                                id="avatar-form-<%= bots[id].id %>" style="display: none;">
                                                <input type="hidden" name="id" value="<%= bots[id].id %>">
                                                <input type="file" name="avatar" id="avatar-input-<%= bots[id].id %>"
                                                    onchange="document.getElementById('avatar-form-<%= bots[id].id %>').submit()">
                                            </form>
                                            <div>
                                                <div style="color: white; font-weight: bold; font-size: 15px;">
                                                    <%= bots[id].botName || 'Unknown Bot' %>
                                                </div>
                                                <div style="font-size: 12px; color: #e0e0e0;">ID: <%= bots[id].id %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <% if(bots[id].status==='online' ) { %>
                                            <form action="/bot/presence" method="POST"
                                                style="display: flex; flex-direction: column; gap: 8px;">
                                                <input type="hidden" name="id" value="<%= bots[id].id %>">
                                                <div style="display: flex; gap: 8px;">
                                                    <select name="status"
                                                        style="padding: 6px; font-size: 12px; width: 100px;">
                                                        <option value="online" <%=bots[id].presence?.status==='online'
                                                            ? 'selected' : '' %>>Online</option>
                                                        <option value="dnd" <%=bots[id].presence?.status==='dnd'
                                                            ? 'selected' : '' %>>DND</option>
                                                        <option value="idle" <%=bots[id].presence?.status==='idle'
                                                            ? 'selected' : '' %>>Idle</option>
                                                        <option value="invisible"
                                                            <%=bots[id].presence?.status==='invisible' ? 'selected' : ''
                                                            %>>Invisible</option>
                                                    </select>
                                                    <select name="type"
                                                        style="padding: 6px; font-size: 12px; width: 100px;">
                                                        <option value="playing" <%=bots[id].presence?.type==='playing'
                                                            ? 'selected' : '' %>>Playing</option>
                                                        <option value="streaming"
                                                            <%=bots[id].presence?.type==='streaming' ? 'selected' : ''
                                                            %>>Streaming</option>
                                                        <option value="listening"
                                                            <%=bots[id].presence?.type==='listening' ? 'selected' : ''
                                                            %>>Listening</option>
                                                        <option value="watching" <%=bots[id].presence?.type==='watching'
                                                            ? 'selected' : '' %>>Watching</option>
                                                    </select>
                                                </div>
                                                <div style="display: flex; gap: 8px;">
                                                    <input type="text" name="text"
                                                        value="<%= bots[id].presence?.text || '' %>"
                                                        placeholder="Status text..."
                                                        style="padding: 6px; font-size: 12px; flex: 1;">
                                                    <button type="submit" class="btn"
                                                        style="padding: 6px 12px; font-size: 12px;"><i
                                                            class="fi fi-rr-refresh"></i></button>
                                                </div>
                                            </form>
                                            <% } else { %>
                                                <span style="color: #aaaaaa; font-size: 13px;"><i
                                                        class="fi fi-rr-cross-circle"></i> Bot Offline</span>
                                                <% } %>
                                    </td>
                                    <td>
                                        <span
                                            style="color: <%= bots[id].status === 'online' ? 'var(--success)' : 'var(--danger)' %>; font-size: 14px; font-weight: bold; display: flex; align-items: center; gap: 5px;">
                                            <i class="fi fi-rr-circle-small" style="font-size: 20px;"></i>
                                            <%= bots[id].status %>
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 8px;">
                                            <% if(bots[id].status==='online' ) { %>
                                                <form action="/bot/stop" method="POST" style="display:inline;">
                                                    <input type="hidden" name="id" value="<%= bots[id].id %>">
                                                    <button type="submit" class="btn btn-danger"
                                                        style="padding: 8px 12px; font-size: 12px;"><i
                                                            class="fi fi-rr-stop"></i> Stop</button>
                                                </form>
                                                <a href="<%= isDemo ? '/demo' : '' %>/server/<%= bots[id].id %>/<%= bots[id].guildId %>" class="btn"
                                                    style="padding: 8px 12px; font-size: 12px; text-decoration: none;"><i
                                                        class="fi fi-rr-settings"></i> Control</a>
                                                <% } else { %>
                                                    <form action="/bot/start" method="POST" style="display:inline;">
                                                        <input type="hidden" name="token" value="<%= bots[id].token %>">
                                                        <input type="hidden" name="guildId"
                                                            value="<%= bots[id].guildId %>">
                                                        <button type="submit" class="btn"
                                                            style="padding: 8px 12px; font-size: 12px;"><i
                                                                class="fi fi-rr-rotate-right"></i> Restart</button>
                                                    </form>
                                                    <% } %>
                                                        <form action="/bot/delete" method="POST" style="display:inline;"
                                                            onsubmit="return confirm('Are you sure you want to delete this bot?')">
                                                            <input type="hidden" name="id" value="<%= bots[id].id %>">
                                                            <button type="submit" class="btn btn-danger"
                                                                style="padding: 8px 12px; font-size: 12px; background: #8a2a2a;"><i
                                                                    class="fi fi-rr-trash"></i> Delete</button>
                                                        </form>
                                        </div>
                                    </td>
                                </tr>
                                <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('addBotForm');
            const tokenInput = document.getElementById('botTokenInput');
            const guildContainer = document.getElementById('guildInputContainer');
            const submitBtn = document.getElementById('submitBotBtn');

            form.addEventListener('submit', async (e) => {
                const token = tokenInput.value.trim();
                const guildIdInput = document.getElementById('guildIdInput');
                const guildIdSelect = document.getElementById('guildIdSelect');
                
                const guildId = (guildIdInput ? guildIdInput.value.trim() : '') || (guildIdSelect ? guildIdSelect.value : '');

                if (guildId) {
                    return;
                }

                e.preventDefault();

                if (!token) {
                    alert('Please enter a Discord Bot Token.');
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fi fi-rr-spinner-alt spin"></i> Fetching Servers...';

                try {
                    const res = await fetch('/bot/guilds', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token })
                    });
                    const data = await res.json();

                    if (data.success && data.guilds && data.guilds.length > 0) {
                        let selectHtml = `
                            <label>Select Server</label>
                            <select name="guildId" id="guildIdSelect" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white; margin-top: 4px;">
                                <option value="">-- Choose a Server --</option>
                        `;
                        data.guilds.forEach(guild => {
                            selectHtml += `<option value="${guild.id}">${guild.name} (${guild.id})</option>`;
                        });
                        selectHtml += `
                            </select>
                            <div style="margin-top: 8px; font-size: 11px;">
                                <a href="#" id="toggleManualGuild" style="color: var(--accent); text-decoration: none;"><i class="fi fi-rr-edit"></i> Or enter ID manually</a>
                            </div>
                        `;
                        
                        guildContainer.innerHTML = selectHtml;

                        document.getElementById('toggleManualGuild').addEventListener('click', (event) => {
                            event.preventDefault();
                            restoreTextInput();
                        });

                        submitBtn.innerHTML = '<i class="fi fi-rr-play"></i> Start Bot';
                    } else if (data.success && (!data.guilds || data.guilds.length === 0)) {
                        alert('This bot is not in any servers. Please invite the bot to a server first, or enter the Server ID manually.');
                        restoreTextInput();
                    } else {
                        alert('Failed to fetch servers: ' + (data.error || 'Check if bot token is valid and has Server/Guilds intent enabled.'));
                        restoreTextInput();
                    }
                } catch (err) {
                    alert('Error connecting to backend: ' + err.message);
                    restoreTextInput();
                } finally {
                    submitBtn.disabled = false;
                }
            });

            function restoreTextInput() {
                guildContainer.innerHTML = `
                    <label>Server ID <span style="font-size: 11px; color: #a1a1aa; font-weight: normal;">(Leave empty to choose from list)</span></label>
                    <input type="text" name="guildId" id="guildIdInput" placeholder="Server ID to manage (Optional)...">
                `;
                submitBtn.innerHTML = '<i class="fi fi-rr-play"></i> Start Bot';
            }
        });
    </script>
</body>

</html>